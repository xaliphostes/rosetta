// C# generation backend. Included by inline/generate.hxx, which provides the
// shared render helpers (subst / includes_of / render_meta / readme /
// write_file) and the jsonable_* predicates this file relies on.
//
// Two artifacts work together:
//   - auto_csharp.cpp: a C++26 shim that registers each reflected type with the
//     runtime in <rosetta/visitors/csharp_visitor.h> and exports a flat C ABI
//     (rosetta_csharp_*). Built into a shared library by the generated CMake.
//   - <Lib>.cs: idiomatic C# wrappers rendered from the reflected IR. Each class
//     is a handle (an integer id into the native store); property/method access
//     is a JSON round-trip through the C ABI via P/Invoke. This part is pure-data
//     templating — no C++ is involved.
//
// The C# surface matches the runtime's: scalars, bool, string, enums (by name),
// and List<…> of those. Members using any other type are skipped on both sides
// (jsonable_type / jsonable_method here mirror cs::supported in the runtime), so
// the wrapper never references a C ABI operation that wasn't registered.

#pragma once

namespace rosetta {
    namespace gen_detail {

        constexpr std::string_view CS_CPP =
            R"CPP(// Generated by rosetta::generate — do not edit by hand.
{{INCLUDES}}#include <rosetta/visitors/csharp_visitor.h>
#include <cstdlib>
#include <cstring>
#include <mutex>
#include <string>

namespace {

void register_all() {
{{BINDINGS}}}

void ensure_registered() {
    static std::once_flag once;
    std::call_once(once, [] { register_all(); });
}

// Copy a std::string into a malloc'd C string; the C# side releases it via
// rosetta_csharp_free. Returns nullptr only on allocation failure.
char *dup_cstr(const std::string &s) {
    char *p = static_cast<char *>(std::malloc(s.size() + 1));
    if (p) {
        std::memcpy(p, s.c_str(), s.size() + 1);
    }
    return p;
}

} // namespace

extern "C" {

ROSETTA_CS_EXPORT int rosetta_csharp_create(const char *type, const char *args) {
    ensure_registered();
    return rosetta::cs::api_create(type, args);
}

ROSETTA_CS_EXPORT int rosetta_csharp_destroy(const char *type, int id) {
    ensure_registered();
    return rosetta::cs::api_destroy(type, id) ? 1 : 0;
}

ROSETTA_CS_EXPORT char *rosetta_csharp_get_field(const char *type, int id, const char *field) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_get(type, id, field));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_set_field(const char *type, int id, const char *field,
                                                 const char *value) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_set(type, id, field, value));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_call_method(const char *type, int id, const char *method,
                                                   const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_call(type, id, method, args));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_call_static(const char *type, const char *method,
                                                   const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_scall(type, method, args));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_call_function(const char *name, const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_function(name, args));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_enum_values(const char *type) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_enum(type));
}

ROSETTA_CS_EXPORT void rosetta_csharp_free(char *p) { std::free(p); }

} // extern "C"
)CPP";

        constexpr std::string_view CS_CMAKE = R"CMK({{HEADER_BLOCK}}
project({{LIB}}_binding CXX)

set(CMAKE_CXX_STANDARD 26)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
