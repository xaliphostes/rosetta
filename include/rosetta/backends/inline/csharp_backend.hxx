  </PropertyGroup>

</Project>
)CSPROJ";

        // -------- C# rendering helpers --------

        // Sanitise an arbitrary library name into a C# identifier usable as a
        // namespace (letters / digits / underscore; must not start with a digit).
        inline std::string cs_ident(const std::string &s) {
            auto is_alnum = [](char ch) {
                return (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') ||
                       (ch >= '0' && ch <= '9');
            };
            auto is_digit = [](char ch) { return ch >= '0' && ch <= '9'; };
            std::string out;
            for (char ch : s) {
                out += (is_alnum(ch) ? ch : '_');
            }
            if (out.empty() || is_digit(out.front())) {
                out.insert(out.begin(), '_');
            }
            return out;
        }

        // Render a neutral GenType as the C# type the wrapper marshals it to.
        // Only ever called for jsonable types; the fallback is defensive.
        inline std::string cs_type(const GenType &t) {
            if (t.kind == "boolean") {
                return "bool";
            }
            if (t.kind == "string") {
                return "string";
            }
            if (t.kind == "number") {
                return t.integer ? "long" : "double";
            }
            if (t.kind == "enum") {
                return t.object.empty() ? "long" : t.object;
            }
            if (t.kind == "vector") {
                return "System.Collections.Generic.List<" +
                       (t.element.empty() ? std::string("object") : cs_type(t.element.front())) +
                       ">";
            }
            return "object";
        }

        // "double arg0, double arg1"
        inline std::string cs_param_sig(const std::vector<GenParam> &ps) {
            std::string s;
            for (std::size_t i = 0; i < ps.size(); ++i) {
                s += (i ? ", " : "") + cs_type(ps[i].type) + " " + ps[i].name;
            }
            return s;
        }

        // "arg0, arg1" — the argument list forwarded to Rt.Args(...).
        inline std::string cs_arg_names(const std::vector<GenParam> &ps) {
            std::string s;
            for (std::size_t i = 0; i < ps.size(); ++i) {
                s += (i ? ", " : "") + ps[i].name;
            }
            return s;
        }

        inline bool cs_ctor_jsonable(const std::vector<GenParam> &ps) {
            for (const auto &p : ps) {
                if (!jsonable_type(p.type)) {
                    return false;
                }
            }
            return true;
        }

        // The fixed runtime helpers (Native P/Invoke surface + Rt marshalling +
        // exception type), emitted once per module.
        inline std::string cs_runtime(const GenContext &c) {
            const std::string lib = c.lib;
            std::string       s;
            s += "    public class RosettaException : System.Exception {\n";
            s += "        public RosettaException(string message) : base(message) { }\n";
            s += "    }\n\n";

            s += "    internal static class Native {\n";
            s += "        private const string LIB = \"" + lib + "\";\n";
            auto str = [](const char *n) {
                return std::string("[System.Runtime.InteropServices.MarshalAs("
                                   "System.Runtime.InteropServices.UnmanagedType.LPUTF8Str)] string ") +
                       n;
            };
            const std::string dll = "        [System.Runtime.InteropServices.DllImport(LIB, "
                                    "CallingConvention = "
                                    "System.Runtime.InteropServices.CallingConvention.Cdecl)]\n";
            s += dll + "        internal static extern int rosetta_csharp_create(" + str("type") +
                 ", " + str("args") + ");\n";
            s += dll + "        internal static extern int rosetta_csharp_destroy(" + str("type") +
                 ", int id);\n";
            s += dll +
                 "        internal static extern System.IntPtr rosetta_csharp_get_field(" +
                 str("type") + ", int id, " + str("field") + ");\n";
            s += dll +
                 "        internal static extern System.IntPtr rosetta_csharp_set_field(" +
                 str("type") + ", int id, " + str("field") + ", " + str("value") + ");\n";
            s += dll +
                 "        internal static extern System.IntPtr rosetta_csharp_call_method(" +
                 str("type") + ", int id, " + str("method") + ", " + str("args") + ");\n";
            s += dll +
                 "        internal static extern System.IntPtr rosetta_csharp_call_static(" +
                 str("type") + ", " + str("method") + ", " + str("args") + ");\n";
            s += dll +
                 "        internal static extern System.IntPtr rosetta_csharp_call_function(" +
                 str("name") + ", " + str("args") + ");\n";
            s += dll +
                 "        internal static extern System.IntPtr rosetta_csharp_enum_values(" +
                 str("type") + ");\n";
            s += dll +
                 "        internal static extern void rosetta_csharp_free(System.IntPtr p);\n";
            s += "    }\n\n";

            s += R"CS(    internal static class Rt {
        // Enums cross the boundary as their underlying integer (the native side
        // marshals them that way), which is System.Text.Json's default for
        // C# enums — so no custom converter is needed.
        private static readonly System.Text.Json.JsonSerializerOptions Opts =
            new System.Text.Json.JsonSerializerOptions();

        private static string Take(System.IntPtr p) {
            if (p == System.IntPtr.Zero) return "";
            string s = System.Runtime.InteropServices.Marshal.PtrToStringUTF8(p) ?? "";
            Native.rosetta_csharp_free(p);
            return s;
        }

        // Parse the {"ok":…,"value":…,"error":…} envelope, throwing on failure.
        private static System.Text.Json.JsonElement Unwrap(System.IntPtr p) {
            string env = Take(p);
            using var doc = System.Text.Json.JsonDocument.Parse(env);
            var root = doc.RootElement;
            if (!root.GetProperty("ok").GetBoolean()) {
                string msg = root.TryGetProperty("error", out var e) ? (e.GetString() ?? "error") : "error";
                throw new RosettaException(msg);
            }
            return root.GetProperty("value").Clone();
        }

        internal static T Get<T>(System.IntPtr p) =>
            System.Text.Json.JsonSerializer.Deserialize<T>(Unwrap(p).GetRawText(), Opts)!;
        internal static void Void(System.IntPtr p) { Unwrap(p); }
        internal static string Args(params object?[] a) =>
            System.Text.Json.JsonSerializer.Serialize(a, Opts);
        internal static string Ser(object? v) =>
            System.Text.Json.JsonSerializer.Serialize(v, Opts);
        internal static int New(string type, string args) {
            int id = Native.rosetta_csharp_create(type, args);
            if (id < 0) throw new RosettaException("failed to construct " + type);
            return id;
        }
    }

)CS";
            return s;
        }

        // One handle-backed wrapper class.
        inline std::string cs_class(const GenClass &k) {
            std::string s;
            if (!k.doc.empty()) {
                s += "    // " + k.name + "\n";
            }
            s += "    public sealed class " + k.name + " : System.IDisposable {\n";
            s += "        private int _id;\n";
            s += "        private const string _t = \"" + k.name + "\";\n\n";

            // Constructors. Dedupe by C# signature so two C++ ctors that erase to
            // the same arity/types don't produce a duplicate member.
            std::vector<std::string> seen_sigs;
            auto                     emit_ctor = [&](const std::vector<GenParam> &ps) {
                const std::string sig = cs_param_sig(ps);
                for (const auto &s2 : seen_sigs) {
                    if (s2 == sig) {
                        return;
                    }
                }
                seen_sigs.push_back(sig);
                const std::string args =
                    ps.empty() ? std::string("\"[]\"") : "Rt.Args(" + cs_arg_names(ps) + ")";
                s += "        public " + k.name + "(" + sig + ") { _id = Rt.New(_t, " + args +
                     "); }\n";
            };
            if (k.is_default_constructible) {
                emit_ctor({});
            }
            for (const auto &ct : k.ctors) {
                if (!ct.empty() && cs_ctor_jsonable(ct)) {
                    emit_ctor(ct);
                }
            }
            if (seen_sigs.empty()) {
                // No JSON-marshalable constructor — block the implicit public
                // parameterless ctor so a broken (id 0) instance can't be made.
                s += "        private " + k.name +
                     "() { } // no JSON-marshalable constructor\n";
            }

            s += "\n        public void Dispose() {\n";
            s += "            if (_id > 0) { Native.rosetta_csharp_destroy(_t, _id); _id = 0; }\n";
            s += "            System.GC.SuppressFinalize(this);\n";
            s += "        }\n";
            s += "        ~" + k.name +
                 "() { if (_id > 0) Native.rosetta_csharp_destroy(_t, _id); }\n";

            // Fields → properties.
            for (const auto &f : k.fields) {
                if (!jsonable_type(f.type)) {
                    continue;
                }
                const std::string ty = cs_type(f.type);
                if (!f.doc.empty()) {
                    s += "\n        /// <summary>" + f.doc + "</summary>";
                }
                s += "\n        public " + ty + " " + f.name + " {\n";
                s += "            get => Rt.Get<" + ty +
                     ">(Native.rosetta_csharp_get_field(_t, _id, \"" + f.name + "\"));\n";
                if (!f.is_readonly) {
                    s += "            set => Rt.Void(Native.rosetta_csharp_set_field(_t, _id, \"" +
                         f.name + "\", Rt.Ser(value)));\n";
                }
                s += "        }\n";
            }

            // Methods.
            for (const auto &m : k.methods) {
                if (!jsonable_method(m)) {
                    continue;
                }
                const std::string sig    = cs_param_sig(m.params);
                const std::string names  = cs_arg_names(m.params);
                const std::string argexp = "Rt.Args(" + names + ")";
                if (!m.doc.empty()) {
                    s += "\n        /// <summary>" + m.doc + "</summary>";
                }
                s += "\n        public " + std::string(m.is_static ? "static " : "");
                const std::string callexpr =
                    m.is_static
                        ? "Native.rosetta_csharp_call_static(_t, \"" + m.name + "\", " + argexp + ")"
                        : "Native.rosetta_csharp_call_method(_t, _id, \"" + m.name + "\", " +
                              argexp + ")";
                if (m.ret.kind == "void") {
                    s += "void " + m.name + "(" + sig + ") => Rt.Void(" + callexpr + ");\n";
                } else {
                    s += cs_type(m.ret) + " " + m.name + "(" + sig + ") => Rt.Get<" +
                         cs_type(m.ret) + ">(" + callexpr + ");\n";
                }
            }

            s += "    }\n\n";
            return s;
        }

        inline std::string csharp_wrapper(const GenContext &c) {
            const std::string ns = cs_ident(c.lib);
            std::string       s  = "// Generated by rosetta::generate — do not edit by hand.\n";
            s += "#nullable enable\n\n";
            s += "namespace " + ns + " {\n\n";

            for (const auto &e : c.enums) {
                if (!e.doc.empty()) {
                    s += "    // " + e.name + "\n";
                }
                s += "    public enum " + e.name + " {\n";
                for (const auto &v : e.values) {
                    s += "        " + v.name + " = " + std::to_string(v.value) + ",\n";
                }
                s += "    }\n\n";
            }

            s += cs_runtime(c);

            for (const auto &k : c.classes) {
                s += cs_class(k);
            }

            // Free functions → a static facade class.
            bool any_fn = false;
            for (const auto &f : c.functions) {
                if (jsonable_function(f)) {
                    any_fn = true;
                    break;
                }
            }
            if (any_fn) {
                s += "    public static class " + cs_ident(c.lib) + "Functions {\n";
                for (const auto &f : c.functions) {
                    if (!jsonable_function(f)) {
                        continue;
                    }
                    const std::string argexp = "Rt.Args(" + cs_arg_names(f.params) + ")";
                    const std::string call =
                        "Native.rosetta_csharp_call_function(\"" + f.name + "\", " + argexp + ")";
                    if (!f.doc.empty()) {
                        s += "        /// <summary>" + f.doc + "</summary>\n";
                    }
                    s += "        public static ";
                    if (f.ret.kind == "void") {
                        s += "void " + f.name + "(" + cs_param_sig(f.params) + ") => Rt.Void(" +
                             call + ");\n";
                    } else {
                        s += cs_type(f.ret) + " " + f.name + "(" + cs_param_sig(f.params) +
                             ") => Rt.Get<" + cs_type(f.ret) + ">(" + call + ");\n";
                    }
                }
                s += "    }\n\n";
            }

            s += "}\n";
            return s;
        }

        // The register_all() body: one bind_csharp* call per exposed entity.
        inline std::string csharp_registrations(const GenContext &c) {
            std::string s;
            for (const auto &e : c.enums) {
                s += "    rosetta::bind_csharp_enum<" + e.name + ">(\"" + e.name + "\");\n";
            }
            for (const auto &k : c.classes) {
                s += "    rosetta::bind_csharp<" + k.name + ">(\"" + k.name + "\");\n";
            }
            for (const auto &f : c.functions) {
                s += "    rosetta::bind_csharp_function<^^" + f.qualified + ">(\"" + f.name +
                     "\");\n";
            }
            return s;
        }

        inline std::string csharp_source(const GenContext &c) {
            // includes_of() also emits the `using namespace` a namespaced user
            // library needs (so unqualified bind_csharp<T> resolves).
            return subst(CS_CPP, {{"INCLUDES", includes_of(c)},
                                  {"BINDINGS", csharp_registrations(c)}});
        }

        inline std::string CSharpBackend::render(const GenContext &c) const {
            return csharp_source(c);
        }

        inline void CSharpBackend::emit(const GenContext &c) const {
            auto dir = c.out_dir / "csharp";
            write_file(dir / "auto_csharp.cpp", csharp_source(c));
            write_file(dir / "CMakeLists.txt", render_meta(CS_CMAKE, c));
            write_file(dir / (c.lib + ".cs"), csharp_wrapper(c));
            write_file(dir / (c.lib + ".csproj"),
                       subst(CS_CSPROJ, {{"LIB", c.lib}, {"NS", cs_ident(c.lib)}}));
            // The standard header/usage, then the per-class reference docs.
            const std::string doc =
                subst(CS_README, {{"LIB", c.lib}, {"NS", cs_ident(c.lib)}}) +
                readme_body_of(c.classes);
            write_file(dir / "README.md", doc);
        }

    } // namespace gen_detail
} // namespace rosetta
