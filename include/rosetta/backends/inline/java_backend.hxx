// Java generation backend. Included by inline/generate.hxx, which provides the
// shared render helpers (subst / includes_of / render_meta / readme /
// write_file / readme_body_of) and the jsonable_* predicates this file relies
// on. The exact sibling of csharp_backend.hxx.
//
// Two artifacts work together:
//   - auto_java.cpp: a C++26 shim that registers each reflected type with the
//     runtime in <rosetta/visitors/java_visitor.h> and exports a flat C ABI
//     (rosetta_java_*). Built into a shared library by the generated CMake.
//   - the Java sources: idiomatic wrappers rendered from the reflected IR. Each
//     class is a handle (an integer id into the native store); property/method
//     access is a JSON round-trip through the C ABI via the Foreign Function &
//     Memory API (java.lang.foreign), with Jackson doing the (de)serialisation.
//     This part is pure-data templating — no C++ is involved.
//
// The Java surface matches the runtime's: scalars, bool, String, enums (by
// value) and List<…> of those. Members using any other type are skipped on both
// sides (jsonable_type / jsonable_method here mirror jvm::supported in the
// runtime), so the wrapper never references a C ABI operation that wasn't
// registered.

#pragma once

namespace rosetta {
    namespace gen_detail {

        // ---- the native shim (auto_java.cpp) ----

        constexpr std::string_view JAVA_CPP =
            R"CPP(// Generated by rosetta::generate — do not edit by hand.
{{INCLUDES}}#include <rosetta/visitors/java_visitor.h>
#include <cstdlib>
#include <cstring>
#include <mutex>
#include <string>

namespace {

void register_all() {
{{BINDINGS}}}

void ensure_registered() {
    static std::once_flag once;
    std::call_once(once, [] { register_all(); });
}

// Copy a std::string into a malloc'd C string; the Java side releases it via
// rosetta_java_free. Returns nullptr only on allocation failure.
char *dup_cstr(const std::string &s) {
    char *p = static_cast<char *>(std::malloc(s.size() + 1));
    if (p) {
        std::memcpy(p, s.c_str(), s.size() + 1);
    }
    return p;
}

} // namespace

extern "C" {

ROSETTA_JAVA_EXPORT int rosetta_java_create(const char *type, const char *args) {
    ensure_registered();
    return rosetta::jvm::api_create(type, args);
}

ROSETTA_JAVA_EXPORT int rosetta_java_destroy(const char *type, int id) {
    ensure_registered();
    return rosetta::jvm::api_destroy(type, id) ? 1 : 0;
}

ROSETTA_JAVA_EXPORT char *rosetta_java_get_field(const char *type, int id, const char *field) {
    ensure_registered();
    return dup_cstr(rosetta::jvm::api_get(type, id, field));
}

ROSETTA_JAVA_EXPORT char *rosetta_java_set_field(const char *type, int id, const char *field,
                                                 const char *value) {
    ensure_registered();
    return dup_cstr(rosetta::jvm::api_set(type, id, field, value));
}

ROSETTA_JAVA_EXPORT char *rosetta_java_call_method(const char *type, int id, const char *method,
                                                   const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::jvm::api_call(type, id, method, args));
}

ROSETTA_JAVA_EXPORT char *rosetta_java_call_static(const char *type, const char *method,
                                                   const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::jvm::api_scall(type, method, args));
}

ROSETTA_JAVA_EXPORT char *rosetta_java_call_function(const char *name, const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::jvm::api_function(name, args));
}

ROSETTA_JAVA_EXPORT char *rosetta_java_enum_values(const char *type) {
    ensure_registered();
    return dup_cstr(rosetta::jvm::api_enum(type));
}

ROSETTA_JAVA_EXPORT void rosetta_java_free(char *p) { std::free(p); }

} // extern "C"
)CPP";

