// Expanded (reflection-free) pybind11 backend. Included by inline/generate.hxx
// after python_backend.h, whose virtual_methods()/trampolines_of() helpers it
// reuses, and after the shared render helpers (subst / num_str / write_file).

#pragma once

namespace rosetta {
    namespace gen_detail {

        // A stock-toolchain CMake: C++17, pybind11, the user's include dir only.
        // No clang-p2996, no -freflection/-fannotation-attributes, no -nostdlib++.
        constexpr std::string_view PYX_CMAKE =
            R"CMK(# Generated by rosetta::generate (expanded, reflection-free) — do not edit by hand.
# These bindings are plain pybind11: NO C++26, NO reflection, NO rosetta headers.
cmake_minimum_required(VERSION 3.18)
project({{LIB}}_binding CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

execute_process(
    COMMAND python3 -c "import sys; print(sys.executable)"
    OUTPUT_VARIABLE Python_EXECUTABLE
    OUTPUT_STRIP_TRAILING_WHITESPACE)
set(Python3_EXECUTABLE "${Python_EXECUTABLE}" CACHE FILEPATH "" FORCE)
set(PYBIND11_FINDPYTHON ON)

if(NOT pybind11_DIR)
    execute_process(
        COMMAND ${Python_EXECUTABLE} -m pybind11 --cmakedir
        OUTPUT_VARIABLE pybind11_DIR
        OUTPUT_STRIP_TRAILING_WHITESPACE)
endif()
find_package(pybind11 REQUIRED CONFIG)

pybind11_add_module({{LIB}} NO_EXTRAS auto_pybind.cpp)

# Only the user's headers — rosetta's include dir is deliberately absent.
target_include_directories({{LIB}} PRIVATE
    {{USER_INCLUDE}})

add_custom_command(TARGET {{LIB}} POST_BUILD
    COMMAND ${CMAKE_COMMAND} -E copy
        $<TARGET_FILE:{{LIB}}>
        ${CMAKE_CURRENT_SOURCE_DIR}/$<TARGET_FILE_NAME:{{LIB}}>)
)CMK";

        // Escape a docstring for a C++ string literal (backslash + quote only;
        // annotation text is short single-line prose in practice).
        inline std::string py_lit(const std::string &s) {
            std::string out;
            for (char ch : s) {
                if (ch == '\\' || ch == '"') {
                    out += '\\';
                }
                out += ch;
            }
            return out;
        }

        // Trailing `, "doc"` for a pybind call, or empty when there is no doc.
        inline std::string doc_arg(const std::string &doc) {
            return doc.empty() ? std::string{} : ", \"" + py_lit(doc) + "\"";
        }

        // Re-qualify standard-library names in an exact type spelling. The
        // p2996 fork's display_string_of prints library types unqualified
        // (`vector<double, allocator<double>>`); a stock compiler needs the
        // `std::`. We word-match a known set of std identifiers and prepend
        // `std::` when the occurrence is a standalone token not already
        // qualified. Only constructor parameter types are spelled out in the
        // emitted code (fields/methods go through member pointers, which keep
        // types implicit), so this is the single place qualification is needed.
        inline std::string qualify_std(std::string s) {
            static constexpr std::string_view names[] = {
                "basic_string", "string_view", "string",  "wstring",     "vector",
                "allocator",    "char_traits", "function", "shared_ptr",  "unique_ptr",
                "unordered_map","unordered_set","map",     "multimap",    "set",
                "multiset",     "pair",        "tuple",    "array",       "list",
                "deque",        "optional",    "variant",  "hash",        "less",
                "equal_to",     "size_t",      "ptrdiff_t"};
            auto ident_char = [](char ch) {
                return (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') ||
                       (ch >= '0' && ch <= '9') || ch == '_';
            };
            for (std::string_view nm : names) {
                std::string::size_type pos = 0;
                while ((pos = s.find(nm, pos)) != std::string::npos) {
                    const bool left_ok =
                        pos == 0 || (!ident_char(s[pos - 1]) && s[pos - 1] != ':');
                    const std::string::size_type end = pos + nm.size();
                    const bool right_ok = end >= s.size() || !ident_char(s[end]);
                    if (left_ok && right_ok) {
                        s.insert(pos, "std::");
                        pos = end + 5; // past the inserted "std::" + name
                    } else {
                        pos = end;
                    }
                }
            }
            return s;
        }

        // The #include block: pybind11 + the user headers. No rosetta header, so
        // the TU pulls in no reflection machinery whatsoever.
        inline std::string expanded_includes(const GenContext &c) {
            std::string s = "#include <pybind11/pybind11.h>\n"
                            "#include <pybind11/stl.h>\n"
                            "#include <pybind11/functional.h>\n";
            auto add = [&](const std::string &h) {
                if (h.empty()) {
                    return;
                }
                const std::string line = "#include \"" + h + "\"\n";
                if (s.find(line) == std::string::npos) {
                    s += line;
                }
            };
            for (const auto &k : c.classes) {
                add(k.header);
            }
            for (const auto &e : c.enums) {
                add(e.header);
            }
            for (const auto &f : c.functions) {
                add(f.header);
            }
            return s;
        }

        // Explicit pybind for one enum: py::enum_<E>(m,"E").value("A", E::A)...;
        inline std::string expanded_enum(const GenEnum &e) {
            std::string s = "    py::enum_<" + e.name + ">(m, \"" + e.name + "\")";
            for (const auto &v : e.values) {
                s += "\n        .value(\"" + v.name + "\", " + e.name + "::" + v.name + ")";
            }
            s += ";\n";
            return s;
        }

        // Explicit pybind for one field, mirroring PybindVisitor::field():
        // readonly -> def_readonly; arithmetic + range -> validating def_property;
        // otherwise def_readwrite. Member pointers keep the field type implicit,
        // so no type spelling is needed except for the range setter's parameter.
        inline std::string expanded_field(const GenClass &k, const GenField &f) {
            const std::string self  = k.name;
            const std::string mp    = "&" + self + "::" + f.name; // member pointer
            const std::string dq    = doc_arg(f.doc);
            if (f.is_readonly) {
                return "    c.def_readonly(\"" + f.name + "\", " + mp + dq + ");\n";
            }
            if (f.range.has && f.type.kind == "number") {
                const std::string ty  = f.type.spelling; // arithmetic -> compilable spelling
                const std::string lo  = num_str(f.range.min);
                const std::string hi  = num_str(f.range.max);
                std::string s;
                s += "    c.def_property(\"" + f.name + "\",\n";
                s += "        [](const " + self + " &s) { return s." + f.name + "; },\n";
                s += "        [](" + self + " &s, " + ty + " v) {\n";
                s += "            if (v < " + lo + " || v > " + hi + ")\n";
                s += "                throw py::value_error(\"" + f.name + " out of range [" + lo +
                     ", " + hi + "]\");\n";
                s += "            s." + f.name + " = v;\n";
                s += "        }" + dq + ");\n";
                return s;
            }
            return "    c.def_readwrite(\"" + f.name + "\", " + mp + dq + ");\n";
        }

        // Explicit pybind for one method. Overloads are already deduped by name
        // in the walk, so the bare &T::m member pointer is unambiguous.
        inline std::string expanded_method(const GenClass &k, const GenMethod &m) {
            const std::string mp = "&" + k.name + "::" + m.name;
            const std::string dq = doc_arg(m.doc);
            if (m.is_static) {
                return "    c.def_static(\"" + m.name + "\", " + mp + dq + ");\n";
            }
            return "    c.def(\"" + m.name + "\", " + mp + dq + ");\n";
        }

        // The constructors, as py::init<...>() lines. Exact param spellings come
        // from GenClass::ctor_param_cpp; a synthetic py::init<>() is added when T
        // is default-constructible but no zero-arg ctor was enumerated.
        inline std::string expanded_ctors(const GenClass &k) {
            std::string s;
            bool        saw_default = false;
            for (const auto &params : k.ctor_param_cpp) {
                if (params.empty()) {
                    saw_default = true;
                }
                std::string args;
                for (std::size_t i = 0; i < params.size(); ++i) {
                    args += (i ? ", " : "") + qualify_std(params[i]);
                }
                s += "    c.def(py::init<" + args + ">());\n";
            }
            if (!saw_default && k.is_default_constructible) {
                s += "    c.def(py::init<>());\n";
            }
            return s;
        }

        // One class block: an open scope so the local `c` never leaks. Uses the
        // trampoline (py::class_<T, Py_T>) when the class has virtual methods —
        // the trampoline classes themselves are emitted, verbatim, by the
        // existing reflection-free trampolines_of() helper.
        inline std::string expanded_class(const GenClass &k) {
            const bool        has_tramp = !virtual_methods(k).empty();
            const std::string decl = has_tramp ? "py::class_<" + k.name + ", rosetta_py::Py_" +
                                                     k.name + ">"
                                               : "py::class_<" + k.name + ">";
            std::string s = "    {\n        " + decl + " c(m, \"" + k.name + "\");\n";
            // The block-local helper lines are written at one indent; reuse the
            // module-level emitters and shift them in by four spaces.
            auto indent = [](const std::string &block) {
                std::string out;
                std::size_t i = 0;
                while (i < block.size()) {
                    std::size_t nl = block.find('\n', i);
                    if (nl == std::string::npos) {
                        nl = block.size();
                    }
                    out += "    " + block.substr(i, nl - i + 1);
                    i = nl + 1;
                }
                return out;
            };
            s += indent(expanded_ctors(k));
            for (const auto &f : k.fields) {
                s += indent(expanded_field(k, f));
            }
            for (const auto &m : k.methods) {
                s += indent(expanded_method(k, m));
            }
            s += "    }\n";
            return s;
        }

        inline std::string python_expanded_source(const GenContext &c) {
            std::string body;
            for (const auto &e : c.enums) {
                body += expanded_enum(e);
            }
            for (const auto &k : c.classes) {
                body += expanded_class(k);
            }
            for (const auto &f : c.functions) {
                body += "    m.def(\"" + f.name + "\", &" + f.qualified + doc_arg(f.doc) + ");\n";
            }

            std::string out = "// Generated by rosetta::generate (expanded, reflection-free) — "
                              "do not edit by hand.\n";
            out += expanded_includes(c);
            out += "\nnamespace py = pybind11;\n";
            out += trampolines_of(c); // reflection-free; empty when no virtuals
            out += "\nPYBIND11_MODULE(" + c.lib + ", m) {\n";
            out += "    m.doc() = \"Auto-generated (expanded) bindings for " + c.lib + ".\";\n";
            out += body;
            out += "}\n";
            return out;
        }

        inline std::string PythonExpandedBackend::render(const GenContext &c) const {
            return python_expanded_source(c);
        }

        inline void PythonExpandedBackend::emit(const GenContext &c) const {
            auto dir = c.out_dir / "python-expanded";
            write_file(dir / "auto_pybind.cpp", python_expanded_source(c));
            write_file(dir / "CMakeLists.txt", render_meta(PYX_CMAKE, c));
            write_file(dir / "README.md", readme("python-expanded", c));
        }

    } // namespace gen_detail
} // namespace rosetta
