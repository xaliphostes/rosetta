// Expanded (reflection-free) C# backend. Included by inline/generate.hxx after
// csharp_backend.h (reuses csharp_wrapper / cs_ident / CS_CSPROJ / CS_README)
// and python_expanded_backend.h (reuses qualify_std), plus the shared render
// helpers (jsonable_*, render_meta, write_file, readme_body_of).
//
// The generated auto_csharp.cpp registers every field / method / constructor by
// pointer, so the runtime deduces the marshalled types from the pointer type —
// no reflection at the target's compile time. The C# side is the same as the
// thin backend's.

#pragma once

namespace rosetta {
    namespace gen_detail {

        // Stock-toolchain CMake: C++20 (member-pointer + class-type NTTPs for the
        // runtime's get_field<&T::f> / fixed_str), the user's headers, and
        // rosetta's include dir purely for the reflection-free csharp_runtime.h.
        // No clang-p2996, no -freflection, no -nostdlib++.
        constexpr std::string_view CSX_CMAKE =
            R"CMK(# Generated by rosetta::generate (expanded, reflection-free) — do not edit by hand.
# Plain shared library reached from .NET via P/Invoke. NO C++26, NO reflection;
# rosetta's include dir is on the path only for the header-only csharp_runtime.h.
cmake_minimum_required(VERSION 3.18)
project({{LIB}}_binding CXX)

set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

include(FetchContent)
FetchContent_Declare(json
    GIT_REPOSITORY https://github.com/nlohmann/json.git
    GIT_TAG        v3.11.3)
FetchContent_MakeAvailable(json)

add_library({{LIB}} SHARED auto_csharp.cpp)
set_target_properties({{LIB}} PROPERTIES
    POSITION_INDEPENDENT_CODE ON
    CXX_VISIBILITY_PRESET hidden
    VISIBILITY_INLINES_HIDDEN ON)

target_include_directories({{LIB}} PRIVATE
    {{USER_INCLUDE}}
    {{ROSETTA_INCLUDE}})

target_link_libraries({{LIB}} PRIVATE nlohmann_json::nlohmann_json)
)CMK";

        // The fixed part of the native shim: ensure_registered + dup_cstr + the
        // exported C ABI. Identical to the thin backend's (only register_all and
        // the includes differ between the two), so both speak the same protocol.
        constexpr std::string_view CSX_ABI = R"CPP(
void ensure_registered() {
    static std::once_flag once;
    std::call_once(once, [] { register_all(); });
}

// Copy a std::string into a malloc'd C string; the C# side releases it via
// rosetta_csharp_free. Returns nullptr only on allocation failure.
char *dup_cstr(const std::string &s) {
    char *p = static_cast<char *>(std::malloc(s.size() + 1));
    if (p) {
        std::memcpy(p, s.c_str(), s.size() + 1);
    }
    return p;
}

} // namespace

extern "C" {

ROSETTA_CS_EXPORT int rosetta_csharp_create(const char *type, const char *args) {
    ensure_registered();
    return rosetta::cs::api_create(type, args);
}

ROSETTA_CS_EXPORT int rosetta_csharp_destroy(const char *type, int id) {
    ensure_registered();
    return rosetta::cs::api_destroy(type, id) ? 1 : 0;
}

ROSETTA_CS_EXPORT char *rosetta_csharp_get_field(const char *type, int id, const char *field) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_get(type, id, field));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_set_field(const char *type, int id, const char *field,
                                                 const char *value) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_set(type, id, field, value));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_call_method(const char *type, int id, const char *method,
                                                   const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_call(type, id, method, args));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_call_static(const char *type, const char *method,
                                                   const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_scall(type, method, args));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_call_function(const char *name, const char *args) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_function(name, args));
}

ROSETTA_CS_EXPORT char *rosetta_csharp_enum_values(const char *type) {
    ensure_registered();
    return dup_cstr(rosetta::cs::api_enum(type));
}

ROSETTA_CS_EXPORT void rosetta_csharp_free(char *p) { std::free(p); }

} // extern "C"
)CPP";

        // A range bound as a `double` literal. set_field_ranged's Lo/Hi are
        // `double` NTTPs, so an integer literal (0) would be ill-formed there —
        // always force a decimal point.
        inline std::string csx_double_lit(double d) {
            std::string s = num_str(d);
            if (s.find('.') == std::string::npos && s.find('e') == std::string::npos &&
                s.find('E') == std::string::npos) {
                s += ".0";
            }
            return s;
        }

        // One class, expanded into an explicit TypeOps registration block.
        inline std::string csx_class(const GenClass &k) {
            const std::string t = k.name;
            std::string       s = "    {\n        rosetta::cs::TypeOps ops;\n";
            s += "        ops.destroy = &rosetta::cs::destroy_inst<" + t + ">;\n";
            if (k.is_default_constructible) {
                s += "        ops.create  = &rosetta::cs::create_default<" + t + ">;\n";
            }

            // Fields → get + (readonly / ranged / plain) set.
            for (const auto &f : k.fields) {
                if (!jsonable_type(f.type)) {
                    continue;
                }
                const std::string mp = "&" + t + "::" + f.name;
                s += "        ops.get[\"" + f.name + "\"] = &rosetta::cs::get_field<" + mp + ">;\n";
                if (f.is_readonly) {
                    s += "        ops.set[\"" + f.name + "\"] = &rosetta::cs::set_field_readonly<" +
                         mp + ", \"" + f.name + "\">;\n";
                } else if (f.range.has && f.type.kind == "number") {
                    s += "        ops.set[\"" + f.name + "\"] = &rosetta::cs::set_field_ranged<" +
                         mp + ", \"" + f.name + "\", " + csx_double_lit(f.range.min) + ", " +
                         csx_double_lit(f.range.max) + ">;\n";
                } else {
                    s += "        ops.set[\"" + f.name + "\"] = &rosetta::cs::set_field<" + mp +
                         ">;\n";
                }
            }

            // Methods → call (instance) / call_function (static; a static member
            // is a plain function pointer).
            for (const auto &m : k.methods) {
                if (!jsonable_method(m)) {
                    continue;
                }
                const std::string mp = "&" + t + "::" + m.name;
                if (m.is_static) {
                    s += "        ops.scall[\"" + m.name + "\"] = &rosetta::cs::call_function<" + mp +
                         ">;\n";
                } else {
                    s += "        ops.call[\"" + m.name + "\"] = &rosetta::cs::call_method<" + mp +
                         ">;\n";
                }
            }

            // Constructors → construct<T, Args...>, keyed by arity. Skip 0-arg
            // (handled by ops.create) and any whose params aren't marshalable.
            for (std::size_t i = 0; i < k.ctor_param_cpp.size(); ++i) {
                const auto &ir = k.ctors[i];
                if (ir.empty()) {
                    continue;
                }
                bool ok = true;
                for (const auto &p : ir) {
                    ok = ok && jsonable_type(p.type);
                }
                if (!ok) {
                    continue;
                }
                std::string types;
                for (const auto &spelling : k.ctor_param_cpp[i]) {
                    types += ", " + qualify_std(spelling);
                }
                s += "        ops.ctors[" + std::to_string(ir.size()) +
                     "] = &rosetta::cs::construct<" + t + types + ">;\n";
            }

            s += "        rosetta::cs::registry()[\"" + t + "\"] = std::move(ops);\n    }\n";
            return s;
        }

        inline std::string csharp_expanded_registrations(const GenContext &c) {
            std::string s;
            // Enums: literal name -> value map (reflection-free).
            for (const auto &e : c.enums) {
                s += "    rosetta::cs::enums()[\"" + e.name + "\"] = rosetta::cs::json{";
                for (std::size_t i = 0; i < e.values.size(); ++i) {
                    s += (i ? ", " : "") + std::string("{\"") + e.values[i].name + "\", " +
                         std::to_string(e.values[i].value) + "}";
                }
                s += "};\n";
            }
            for (const auto &k : c.classes) {
                s += csx_class(k);
            }
            for (const auto &f : c.functions) {
                if (jsonable_function(f)) {
                    s += "    rosetta::cs::functions()[\"" + f.name +
                         "\"] = &rosetta::cs::call_function<&" + f.qualified + ">;\n";
                }
            }
            return s;
        }

        inline std::string csharp_expanded_source(const GenContext &c) {
            std::string out =
                "// Generated by rosetta::generate (expanded, reflection-free) — "
                "do not edit by hand.\n";
            out += "#include <rosetta/backends/csharp_runtime.h>\n";
            out += "#include <cstdlib>\n#include <cstring>\n#include <mutex>\n#include <string>\n";
            // User headers (deduped) — the only thing the shim needs besides the
            // runtime; no rosetta/annotations.h (these headers are stock C++).
            auto add = [&](const std::string &h) {
                if (h.empty()) {
                    return;
                }
                const std::string line = "#include \"" + h + "\"\n";
                if (out.find(line) == std::string::npos) {
                    out += line;
                }
            };
            for (const auto &k : c.classes) {
                add(k.header);
            }
            for (const auto &e : c.enums) {
                add(e.header);
            }
            for (const auto &f : c.functions) {
                add(f.header);
            }
            out += using_namespaces_of(c); // `using namespace` for namespaced user types
            out += "\nnamespace {\n\nvoid register_all() {\n";
            out += csharp_expanded_registrations(c);
            out += "}\n";
            out += CSX_ABI;
            return out;
        }

        inline std::string CSharpExpandedBackend::render(const GenContext &c) const {
            return csharp_expanded_source(c);
        }

        inline void CSharpExpandedBackend::emit(const GenContext &c) const {
            auto dir = c.out_dir / "csharp-expanded";
            write_file(dir / "auto_csharp.cpp", csharp_expanded_source(c));
            write_file(dir / "CMakeLists.txt", render_meta(CSX_CMAKE, c));
            // The C# wrapper / project are identical to the thin backend's.
            write_file(dir / (c.lib + ".cs"), csharp_wrapper(c));
            write_file(dir / (c.lib + ".csproj"),
                       subst(CS_CSPROJ, {{"LIB", c.lib}, {"NS", cs_ident(c.lib)}}));
            const std::string doc =
                subst(CS_README, {{"LIB", c.lib}, {"NS", cs_ident(c.lib)}}) +
                readme_body_of(c.classes);
            write_file(dir / "README.md", doc);
        }

    } // namespace gen_detail
} // namespace rosetta
