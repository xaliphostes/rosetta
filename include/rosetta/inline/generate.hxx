        // -------- emitter dispatch --------

        // Per-generator context. The per-class bindings are backend-specific
        // and built once; `lib_name` is the module name and varies per target.
        struct Ctx {
            std::string lib_name;
            std::string includes;   // all `#include "..."` lines
            std::string py_binds;   // pybind registration lines
            std::string node_binds; // N-API export lines
            std::string rest_binds; // REST store + route lines
            std::string web_binds;  // emscripten binding lines
            std::string user_include;
            std::string rosetta_include;
            std::string readme_body;
        };

        // CMake / package vars — backend source uses {{INCLUDES}}/{{BINDINGS}}
        // which are passed separately by render_source().
        inline std::string render_meta(std::string_view tmpl, const Ctx &c) {
            return render(tmpl, {{"LIB", c.lib_name},
                                 {"HEADER_BLOCK", CMAKE_HEADER},
                                 {"USER_INCLUDE", c.user_include},
                                 {"ROSETTA_INCLUDE", c.rosetta_include}});
        }

        inline std::string
        render_source(std::string_view tmpl, const Ctx &c, std::string_view binds) {
            return render(tmpl, {{"LIB", c.lib_name},
                                 {"INCLUDES", c.includes},
                                 {"BINDINGS", binds}});
        }

        inline std::string readme(std::string_view backend, const Ctx &c) {
            std::string s = "# `" + c.lib_name + "` (";
            s += backend;
            s += ")\n\nAuto-generated bindings.\n\n";
            s += c.readme_body;
            return s;
        }

        inline void emit_python(const std::filesystem::path &root, const Ctx &c) {
            auto dir = root / "python";
            write_file(dir / "auto_pybind.cpp", render_source(PY_CPP, c, c.py_binds));
            write_file(dir / "CMakeLists.txt", render_meta(PY_CMAKE, c));
            write_file(dir / "README.md", readme("python", c));
        }

        inline void emit_node(const std::filesystem::path &root, const Ctx &c) {
            auto dir = root / "node";
            write_file(dir / "auto_napi.cpp", render_source(NODE_CPP, c, c.node_binds));
            write_file(dir / "CMakeLists.txt", render_meta(NODE_CMAKE, c));
            write_file(dir / "package.json", render_meta(NODE_PACKAGE, c));
            write_file(dir / "README.md", readme("node", c));
        }

        inline void emit_rest(const std::filesystem::path &root, const Ctx &c) {
            auto dir = root / "rest";
            write_file(dir / "auto_rest.cpp", render_source(REST_CPP, c, c.rest_binds));
            write_file(dir / "CMakeLists.txt", render_meta(REST_CMAKE, c));
            write_file(dir / "README.md", readme("rest", c));
        }

        inline void emit_web(const std::filesystem::path &root, const Ctx &c) {
            auto dir = root / "web";
            write_file(dir / "auto_emscripten.cpp", render_source(WEB_CPP, c, c.web_binds));
            write_file(dir / "CMakeLists.txt", render_meta(WEB_CMAKE, c));
            write_file(dir / "README.md", readme("web", c));
        }

    } // namespace gen_detail

    /**
     * @brief Scaffold the per-backend binding projects for the whole set of
     * classes `Ts...` under opt.out_dir. Each backend gets one combined
     * module (named per `opt.targets`) registering every class.
     */
    template <typename... Ts> inline void generate(const GenerateOptions &opt) {
        using gen_detail::class_name;

        gen_detail::Ctx c;
        c.user_include    = opt.user_include.string();
        c.rosetta_include = opt.rosetta_include.string();

        // Header includes — one per class, shared by every backend.
        ((c.includes += "#include \"" + std::string(binding_info<Ts>::header) + "\"\n"), ...);

        // Per-backend registration bodies, built once across the class pack.
        ((c.py_binds += "    rosetta::bind_pybind<" + class_name<Ts>() + ">(m, \"" +
                        class_name<Ts>() + "\");\n"),
         ...);
        ((c.node_binds += "    exports.Set(\"" + class_name<Ts>() + "\", rosetta::bind_napi<" +
                          class_name<Ts>() + ">(env, \"" + class_name<Ts>() + "\"));\n"),
         ...);
        ((c.rest_binds += "    rosetta::Store<" + class_name<Ts>() + "> store_" +
                          class_name<Ts>() + ";\n    rosetta::bind_rest<" + class_name<Ts>() +
                          ">(server, \"/" + class_name<Ts>() + "\", store_" + class_name<Ts>() +
                          ");\n"),
         ...);
        ((c.web_binds += "    rosetta::bind_wasm<" + class_name<Ts>() + ">(\"" +
                         class_name<Ts>() + "\");\n"),
         ...);

        // README body — concatenated per-class reference docs.
        ((c.readme_body += generate_markdown<Ts>() + "\n"), ...);

        for (const TargetSpec &t : opt.targets) {
            c.lib_name = t.name;
            if (t.lang == "python")
                gen_detail::emit_python(opt.out_dir, c);
            else if (t.lang == "node")
                gen_detail::emit_node(opt.out_dir, c);
            else if (t.lang == "rest")
                gen_detail::emit_rest(opt.out_dir, c);
            else if (t.lang == "web")
                gen_detail::emit_web(opt.out_dir, c);
        }
    }

} // namespace rosetta
