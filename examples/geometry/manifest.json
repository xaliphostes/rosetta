            "lang": "markdown"
        }
    ],
    "classes": [
        {
            "doc": "Just to show that we can define a new name given a header",
            "name": "Model",
            "header": "Model.h"
        },
        {
            "header": "Point.h"
        },
        {
            "header": "Surface.h"
        },
        {
            "header": "Triangle.h"
        },
        {
            "header": "Kind.h"
        }
    ],
    "functions": [
        {
            "doc": "Scale and swizzle a point into (x*2, z*3, y*4)",
            "header": "common.h",
            "name": "transform"
        }
    ]
}