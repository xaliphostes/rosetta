{
    "user_include": "./geom",
    "rosetta_include": "../../include",
    "targets": [
        {
            "doc": "Automatique Python binding",
            "lang": "python",
            "name": "pygeom"
        },
        {
            "doc": "Automatique node (JavaScript) binding",
            "lang": "node",
            "name": "jsgeom"
        },
        {
            "doc": "Will generate TypeScript interfaces",
